{
  "name": "invite",
  "metadata": {
    "description": "User invitation email (sent by User.send_invite).",
    "context_keys": [
      "user",
      "token"
    ],
    "notes": [
      "`user` is a dict (user.to_dict('basic')).",
      "`token` is an invitation token string.",
      "Some callers may pass additional context keys; keep templates resilient to extra data."
    ]
  },
  "subject_template": "You're invited{% if user.display_name %}, {{ user.display_name }}{% endif %}",
  "text_template": "Hello{% if user.display_name %} {{ user.display_name }}{% endif %},\n\nYou've been invited to join.\n\nUse this token to continue:\n{{ token }}\n\nIf you didn't request this, you can ignore this email.\n",
  "html_template": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Invitation</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#f6f7f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#111;\">\n    <div style=\"max-width:640px;margin:0 auto;padding:24px;\">\n      <div style=\"background:#ffffff;border:1px solid #e6e8ec;border-radius:10px;padding:24px;\">\n        <h1 style=\"margin:0 0 12px 0;font-size:20px;line-height:1.3;\">You're invited</h1>\n        <p style=\"margin:0 0 16px 0;font-size:14px;line-height:1.6;color:#333;\">\n          Hello{% if user.display_name %} {{ user.display_name }}{% endif %},\n        </p>\n        <p style=\"margin:0 0 16px 0;font-size:14px;line-height:1.6;color:#333;\">\n          You've been invited to join. Use the token below to continue.\n        </p>\n\n        <div style=\"margin:16px 0;padding:14px 16px;background:#f6f7f9;border:1px solid #e6e8ec;border-radius:8px;\">\n          <div style=\"font-size:12px;color:#555;margin-bottom:6px;\">Invitation token</div>\n          <div style=\"font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,'Liberation Mono','Courier New',monospace;font-size:14px;color:#111;word-break:break-all;\">{{ token }}</div>\n        </div>\n\n        <p style=\"margin:16px 0 0 0;font-size:12px;line-height:1.6;color:#666;\">\n          If you didn't request this, you can ignore this email.\n        </p>\n      </div>\n\n      <div style=\"text-align:center;margin-top:14px;font-size:12px;color:#8a8f98;\">\n        Sent by Django-MOJO\n      </div>\n    </div>\n  </body>\n</html>\n"
}
